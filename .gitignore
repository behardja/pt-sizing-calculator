# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
# Virtual envs
.venv/
venv/
env/

# ── Node / Vite ───────────────────────────────────────────────────────────
node_modules/
# Built frontend bundle — regenerated by `npm run build` / server.py
frontend/dist/
# Vite caches
.vite/
**/.vite/
# Tool logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# Keep package-lock.json tracked — it pins deps for reproducible installs.

# ── Terraform ─────────────────────────────────────────────────────────────
# Local plugin cache + module sources
.terraform/
.terraform.tfstate.lock.info
# State files — never commit; may contain SA emails, project IDs, etc.
*.tfstate
*.tfstate.*
*.tfstate.backup
# tfvars often contains project IDs / personal config — keep .example tracked
*.tfvars
*.tfvars.json
!*.tfvars.example
# Crash logs
crash.log
crash.*.log
# Keep .terraform.lock.hcl tracked — it pins provider versions.

# ── Credentials / secrets ─────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
# Service account keys (don't use these — impersonate instead)
*-service-account.json
*-sa-key.json
# gcloud ADC dumped into the repo by mistake
application_default_credentials.json

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Editors / OS ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Misc local ────────────────────────────────────────────────────────────
# Local scratchpads, ad-hoc notes
TODO.local.md
NOTES.local.md
